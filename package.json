{
  "name": "swrm",
  "version": "0.3.0",
  "description": "MCP-native kanban for parallel coding agents. Markdown-friendly. Localhost-first.",
  "bin": {
    "swrm": "dist/cli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist/migrations && cp -r src/migrations dist/migrations && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepare": "[ -d src ] && npm run build || true",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "author": "Erick Bzovi",
  "homepage": "https://github.com/ballinbigE/swrm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ballinbigE/swrm.git"
  },
  "bugs": {
    "url": "https://github.com/ballinbigE/swrm/issues"
  },
  "keywords": [
    "kanban",
    "mcp",
    "ai-agents",
    "claude-code",
    "codex",
    "gemini",
    "git-worktree",
    "project-management",
    "localhost"
  ],
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsdown": "^0.7.0",
    "tsx": "^4.0.0",
    "typescript": "~5.9.2"
  }
}
