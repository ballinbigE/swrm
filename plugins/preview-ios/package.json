{
  "name": "@swrm/preview-ios",
  "version": "0.1.0",
  "description": "iOS Simulator screenshot preview plugin for swrm. Renders the booted iPhone's screen into the workspace right pane.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=20" },
  "license": "Apache-2.0",
  "peerDependencies": {
    "swrm": "^0.1.0"
  },
  "scripts": {
    "build": "tsdown",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.7.0",
    "typescript": "~5.9.2",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0"
  },
  "keywords": ["swrm-plugin", "preview", "ios", "simulator"]
}
